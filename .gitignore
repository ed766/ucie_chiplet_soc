# Simulation build outputs
/base_soc/sim/build/
/base_soc/sim/obj_dir/

# LibreLane/OpenLane generated runs
/chiplet_extension/build/
/chiplet_extension/logs/
/chiplet_extension/openlane/chiplet/runs/

# Chiplet report policy:
# keep curated summaries and docs under version control, but ignore raw
# per-test/per-seed regression artifacts generated by local runs.
/chiplet_extension/reports/*
!/chiplet_extension/reports/.gitkeep
!/chiplet_extension/reports/README.md
!/chiplet_extension/reports/regress_summary.csv
!/chiplet_extension/reports/coverage_summary.csv
!/chiplet_extension/reports/failure_buckets.csv
